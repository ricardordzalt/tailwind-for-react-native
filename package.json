{
  "repository": {
    "type": "git",
    "url": "https://github.com/ricardordzalt/tailwind-for-react-native"
  },
  "name": "tailwind-for-react-native",
  "version": "0.0.25",
  "description": "Tailwind for react native",
  "private": false,
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "types",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run test -- --runInBand && npm run build",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.78.0",
    "@types/jest": "^30.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^30.2.0",
    "react-native": "0.78.0",
    "react-test-renderer": "19.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}