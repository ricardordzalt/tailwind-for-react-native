{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "jsx": "react-native",
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": ["example", "__tests__", "dist", "node_modules"]
}
